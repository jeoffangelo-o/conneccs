<%- include('../partials/header') %>

<main class="main-content messages-fullscreen">
  <div class="discord-layout">
    <!-- Channel Sidebar -->
    <aside class="channel-sidebar">
      <div class="channel-header">
        <a href="/" style="display: flex; align-items: center; gap: 8px; color: var(--text); text-decoration: none;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          <span style="font-weight: 600;">Back to Dashboard</span>
        </a>
      </div>
      
      <div class="channel-header" style="border-top: 1px solid var(--border); margin-top: 8px; padding-top: 16px;">
        <h3>CCS Channels</h3>
      </div>
      
      <div class="channel-list">
        <div class="channel-section">
          <div class="channel-section-label">TEXT CHANNELS</div>
          <% channels.forEach(channel => { %>
            <% if (channel.allowedRoles.includes(userRole)) { %>
              <a href="#" class="channel-item <%= activeChannel === channel.id ? 'active' : '' %>" 
                 data-channel-id="<%= channel.id %>"
                 onclick="switchChannel('<%= channel.id %>'); return false;">
                <svg class="channel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <span class="channel-name"><%= channel.name %></span>
              </a>
            <% } %>
          <% }); %>
        </div>

        <div class="channel-section">
          <div class="channel-section-label">DIRECT MESSAGES</div>
          <a href="#" class="channel-item">
            <div class="dm-avatar">D</div>
            <span class="channel-name">Dean's Office</span>
          </a>
        </div>
      </div>

      <div class="user-panel">
        <div class="user-panel-avatar"><%= userName.charAt(0) %></div>
        <div class="user-panel-info">
          <div class="user-panel-name"><%= userName %></div>
          <div class="user-panel-status">
            <span class="status-indicator online"></span>
            Online
          </div>
        </div>
        <!-- Theme Toggle Button -->
        <button onclick="toggleTheme()" class="theme-toggle-btn" title="Toggle theme">
          <svg class="theme-icon sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="theme-icon moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </aside>

    <!-- Chat Area -->
    <div class="chat-container">
      <div class="chat-header">
        <div class="chat-header-left">
          <svg class="channel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          <span class="chat-channel-name" id="currentChannelName"><%= activeChannelName %></span>
        </div>
        <div class="chat-header-right">
          <button class="icon-btn" onclick="toggleMemberList()" title="Members">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </button>
          <button class="icon-btn" onclick="openGoogleDrive()" title="Google Drive">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
              <polyline points="13 2 13 9 20 9"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="chat-messages" id="chatMessages">
        <div style="text-align: center; padding: 2rem; color: var(--text3);">
          <div style="display: inline-block; width: 20px; height: 20px; border: 2px solid var(--text3); border-radius: 50%; border-top-color: var(--accent); animation: spin 1s linear infinite; margin-bottom: 1rem;"></div>
          <p>Loading messages...</p>
        </div>
      </div>

      <div class="chat-input-container">
        <form id="messageForm" onsubmit="sendMessage(event)">
          <div class="chat-input-wrapper">
            <input type="file" id="fileInput" style="display: none;" onchange="handleFileSelect(event)" multiple>
            <button type="button" class="attach-btn" onclick="attachFile()" title="Attach file">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
              </svg>
            </button>
            <textarea id="messageInput" 
                      placeholder="Message #<%= activeChannelName %> (use @ to mention roles)" 
                      autocomplete="off"
                      rows="1"
                      onkeyup="handleMentions(event)"
                      onkeydown="handleMentionKeydown(event)"></textarea>
            <button type="submit" class="send-btn" title="Send message">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </button>
          </div>
          <div id="attachedFiles" class="attached-files"></div>
          <div id="mentionSuggestions" class="mention-suggestions"></div>
        </form>
      </div>
    </div>

    <!-- Member List Sidebar -->
    <aside class="member-sidebar" id="memberSidebar">
      <div class="member-section">
        <div class="member-section-label">DEAN — 1</div>
        <div class="member-item">
          <div class="member-avatar">D</div>
          <span class="member-name">Dean's Office</span>
          <span class="status-indicator online"></span>
        </div>
      </div>

      <div class="member-section">
        <div class="member-section-label">PROGRAM CHAIRS — 2</div>
        <div class="member-item">
          <div class="member-avatar">P</div>
          <span class="member-name">Dr. Pedro Cruz</span>
          <span class="status-indicator online"></span>
        </div>
        <div class="member-item">
          <div class="member-avatar">M</div>
          <span class="member-name">Dr. Maria Santos</span>
          <span class="status-indicator offline"></span>
        </div>
      </div>

      <div class="member-section">
        <div class="member-section-label">FACULTY — <%= faculty.length %></div>
        <% faculty.slice(0, 10).forEach(f => { %>
          <div class="member-item">
            <div class="member-avatar"><%= f.name.charAt(0) %></div>
            <span class="member-name"><%= f.name %></span>
            <span class="status-indicator <%= Math.random() > 0.5 ? 'online' : 'offline' %>"></span>
          </div>
        <% }); %>
      </div>
    </aside>
  </div>
</main>

<!-- Google Drive Modal -->
<div id="driveModal" class="modal" style="display: none;">
  <div class="modal-content drive-modal">
    <div class="modal-header">
      <h3>Google Drive - CCS Documents</h3>
      <button onclick="closeGoogleDrive()" class="modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <div id="driveContent">
        <div class="drive-toolbar">
          <button onclick="uploadToDrive()" class="btn btn-primary btn-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            Upload File
          </button>
          <input type="text" placeholder="Search files..." class="drive-search">
        </div>
        <div id="driveFileList" class="drive-file-list">
          <!-- Files will be loaded here -->
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Image Preview Modal -->
<div id="imagePreviewModal" class="modal" style="display: none;">
  <div class="modal-content image-preview-modal">
    <div class="modal-header">
      <h3 id="imagePreviewTitle">Image Preview</h3>
      <button onclick="closeImagePreview()" class="modal-close">&times;</button>
    </div>
    <div class="modal-body" style="text-align: center; padding: 0;">
      <img id="imagePreviewImg" src="" alt="" style="max-width: 100%; max-height: 70vh; object-fit: contain;">
    </div>
  </div>
</div>

<!-- Document Preview Modal -->
<div id="documentPreviewModal" class="modal" style="display: none;">
  <div class="modal-content document-preview-modal">
    <div class="modal-header">
      <h3 id="documentPreviewTitle">Document Preview</h3>
      <div class="document-actions">
        <button onclick="downloadDocument()" class="btn btn-sm btn-secondary" id="downloadBtn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download
        </button>
        <button onclick="openInNewTab()" class="btn btn-sm btn-secondary" id="openNewTabBtn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Open
        </button>
        <button onclick="closeDocumentPreview()" class="modal-close">&times;</button>
      </div>
    </div>
    <div class="modal-body" style="padding: 0; height: 70vh; position: relative;">
      <div id="documentLoadingIndicator" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: var(--text3);">
        <div style="display: inline-block; width: 20px; height: 20px; border: 2px solid var(--text3); border-radius: 50%; border-top-color: var(--accent); animation: spin 1s linear infinite; margin-bottom: 1rem;"></div>
        <p>Loading document preview...</p>
      </div>
      <iframe id="documentPreviewFrame" src="" style="width: 100%; height: 100%; border: none; display: none;"></iframe>
    </div>
  </div>
</div>

<script>
let currentChannel = '<%= activeChannel %>';
let currentUser = {
  id: '<%= userId %>',
  name: '<%= userName %>',
  role: '<%= userRole %>'
};
let lastMessageId = 0;

// Theme toggle function
function toggleTheme() {
  const currentTheme = document.documentElement.getAttribute('data-theme');
  const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
  
  document.documentElement.setAttribute('data-theme', newTheme);
  localStorage.setItem('theme', newTheme);
}

// Load messages for current channel (with aggressive timeout)
function loadMessages() {
  console.log('Loading messages for channel:', currentChannel);
  
  const container = document.getElementById('chatMessages');
  
  // Show immediate fallback after 2 seconds
  const fallbackTimeout = setTimeout(() => {
    container.innerHTML = `<div style="text-align: center; padding: 2rem; color: var(--text3);">
      <div style="margin-bottom: 1rem;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <p style="margin-bottom: 1rem;">Server not responding</p>
      <p style="font-size: 0.85rem; color: var(--text3); margin-bottom: 1rem;">You can still use the interface</p>
      <button onclick="loadMessages()" class="btn btn-primary btn-sm">Try Again</button>
    </div>`;
  }, 2000); // 2 second fallback
  
  // Show loading state
  container.innerHTML = '<div style="text-align: center; padding: 2rem; color: var(--text3);"><div style="display: inline-block; width: 20px; height: 20px; border: 2px solid var(--text3); border-radius: 50%; border-top-color: var(--accent); animation: spin 1s linear infinite;"></div><p style="margin-top: 1rem;">Loading messages...</p></div>';
  
  // Try to fetch with very short timeout
  const controller = new AbortController();
  const fetchTimeout = setTimeout(() => {
    controller.abort();
  }, 3000); // 3 second fetch timeout
  
  fetch(`/messages/api/channel/${currentChannel}`, {
    signal: controller.signal
  })
    .then(res => {
      clearTimeout(fallbackTimeout);
      clearTimeout(fetchTimeout);
      if (!res.ok) {
        throw new Error(`Server error: ${res.status}`);
      }
      return res.json();
    })
    .then(data => {
      container.innerHTML = '';
      
      if (!data.messages || data.messages.length === 0) {
        container.innerHTML = '<div style="text-align: center; padding: 2rem; color: var(--text3);">No messages yet. Start the conversation!</div>';
        return;
      }
      
      data.messages.forEach(msg => {
        appendMessage(msg);
        lastMessageId = Math.max(lastMessageId, msg.id);
      });
      
      scrollToBottom();
    })
    .catch(err => {
      clearTimeout(fetchTimeout);
      // Don't clear fallbackTimeout - let it show the fallback
      console.error('Error loading messages:', err);
    });
}

// Append message to chat with Discord-style grouping
function appendMessage(msg) {
  const container = document.getElementById('chatMessages');
  const isOwnMessage = msg.userId === currentUser.id;
  const isMentioned = msg.mentions.includes(currentUser.role) || msg.mentions.includes('@' + currentUser.id);
  
  // IMPORTANT: Only show message if:
  // 1. No mentions (public message), OR
  // 2. Current user is mentioned, OR
  // 3. Current user is the sender
  const canSeeMessage = msg.mentions.length === 0 || isMentioned || isOwnMessage;
  
  if (!canSeeMessage) {
    return; // Don't display this message
  }
  
  // Check if this message should be grouped with the previous one
  const lastMessage = container.lastElementChild;
  const shouldGroup = lastMessage && 
    lastMessage.dataset.userId === msg.userId.toString() && 
    lastMessage.dataset.timestamp && 
    (new Date(msg.timestamp) - new Date(parseInt(lastMessage.dataset.timestamp))) < 300000; // 5 minutes
  
  const messageEl = document.createElement('div');
  messageEl.className = `chat-message ${isOwnMessage ? 'own-message' : ''} ${isMentioned ? 'mentioned' : ''} ${shouldGroup ? 'grouped' : ''}`;
  messageEl.dataset.userId = msg.userId;
  messageEl.dataset.messageId = msg.id; // Add message ID for actions
  messageEl.dataset.timestamp = new Date(msg.timestamp).getTime();
  
  messageEl.innerHTML = `
    <div class="message-avatar">${msg.userName.charAt(0)}</div>
    <div class="message-content">
      ${msg.replyTo ? `
        <div class="message-reply-preview">
          <div class="message-reply-author">${msg.replyTo.author}</div>
          <div class="message-reply-text">${msg.replyTo.text}</div>
        </div>
      ` : ''}
      <div class="message-header">
        <div class="message-header-left">
          <span class="message-author">${msg.userName}</span>
          <span class="message-role role-${msg.userRole}">${msg.userRole.replace('_', ' ')}</span>
        </div>
        <div class="message-header-right">
          <span class="message-time">${formatTime(msg.timestamp)}</span>
          ${msg.mentions.length > 0 ? `
            <svg class="message-lock-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" title="Only visible to ${msg.mentions.map(m => '@' + m).join(', ')}">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          ` : `
            <svg class="message-public-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" title="Visible to everyone in this channel">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          `}
        </div>
      </div>
      ${msg.message ? `<div class="message-text">${formatMessage(msg.message)}</div>` : ''}
      ${msg.attachments.length > 0 ? `
        <div class="message-attachments">
          ${msg.attachments.map(att => {
            const isImage = att.type && att.type.startsWith('image/');
            const isPDF = att.type === 'application/pdf';
            const isDoc = att.type && (att.type.includes('document') || att.type.includes('word') || att.type.includes('sheet') || att.type.includes('presentation'));
            
            if (isImage) {
              return `
                <div class="attachment-image">
                  <img src="${att.url}" alt="${att.name}" onclick="openImagePreview('${att.url}', '${att.name}')" style="max-width: 400px; max-height: 300px; border-radius: 12px; cursor: pointer; margin: 4px 0;">
                  <div class="image-caption">${att.name} (${att.size})</div>
                </div>
              `;
            } else if (isPDF || isDoc) {
              return `
                <div class="attachment-document" onclick="openDocumentPreview('${att.url}', '${att.name}', '${att.type}')" style="cursor: pointer;">
                  <div class="document-preview-card">
                    <div class="document-icon">
                      ${isPDF ? `
                        <svg viewBox="0 0 24 24" fill="none" stroke="#d32f2f" stroke-width="2" style="width: 16px; height: 16px;">
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                          <polyline points="14 2 14 8 20 8"/>
                          <line x1="16" y1="13" x2="8" y2="13"/>
                          <line x1="16" y1="17" x2="8" y2="17"/>
                        </svg>
                      ` : `
                        <svg viewBox="0 0 24 24" fill="none" stroke="#1976d2" stroke-width="2" style="width: 16px; height: 16px;">
                          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                          <polyline points="14 2 14 8 20 8"/>
                          <line x1="8" y1="13" x2="16" y2="17"/>
                          <line x1="8" y1="17" x2="16" y2="13"/>
                        </svg>
                      `}
                    </div>
                    <div class="document-info">
                      <div class="document-name">${att.name}</div>
                      <div class="document-size">${att.size}</div>
                    </div>
                    <div class="document-preview-btn">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 12px; height: 12px;">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                      </svg>
                      Preview
                    </div>
                  </div>
                </div>
              `;
            } else {
              return `
                <a href="${att.url}" target="_blank" class="attachment-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
                    <polyline points="13 2 13 9 20 9"/>
                  </svg>
                  <div class="attachment-info">
                    <div class="attachment-name">${att.name}</div>
                    <div class="attachment-size">${att.size}</div>
                  </div>
                </a>
              `;
            }
          }).join('')}
        </div>
      ` : ''}
      <div class="message-actions">
        <button class="message-action-btn" data-action="reaction" data-message-id="${msg.id}" data-emoji="👍" title="Add reaction">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
            <line x1="9" y1="9" x2="9.01" y2="9"/>
            <line x1="15" y1="9" x2="15.01" y2="9"/>
          </svg>
        </button>
        <button class="message-action-btn" data-action="reply" data-message-id="${msg.id}" title="Reply">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 17 4 12 9 7"/>
            <path d="M20 18v-2a4 4 0 0 0-4-4H4"/>
          </svg>
        </button>
        ${isOwnMessage ? `
          <button class="message-action-btn" data-action="edit" data-message-id="${msg.id}" title="Edit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </button>
          <button class="message-action-btn" data-action="delete" data-message-id="${msg.id}" title="Delete">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
              <line x1="10" y1="11" x2="10" y2="17"/>
              <line x1="14" y1="11" x2="14" y2="17"/>
            </svg>
          </button>
        ` : ''}
        <button class="message-action-btn" data-action="more" data-message-id="${msg.id}" title="More">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="1"/>
            <circle cx="19" cy="12" r="1"/>
            <circle cx="5" cy="12" r="1"/>
          </svg>
        </button>
      </div>
    </div>
  `;
  
  container.appendChild(messageEl);
}

// Discord-style message actions
let replyingToMessage = null;
let editingMessage = null;

function addReaction(messageId, emoji) {
  console.log('Adding reaction:', emoji, 'to message:', messageId);
  // Implementation for reactions
  fetch('/messages/api/reaction', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      messageId: messageId,
      emoji: emoji,
      channelId: currentChannel
    })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      // Update reaction display
      updateMessageReactions(messageId, data.reactions);
    }
  })
  .catch(err => console.error('Error adding reaction:', err));
}

function replyToMessage(messageId) {
  console.log('Replying to message:', messageId);
  
  // Find the message element
  const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
  if (!messageEl) return;
  
  const authorName = messageEl.querySelector('.message-author').textContent;
  const messageText = messageEl.querySelector('.message-text').textContent;
  
  // Set reply state
  replyingToMessage = {
    id: messageId,
    author: authorName,
    text: messageText.length > 50 ? messageText.substring(0, 50) + '...' : messageText
  };
  
  // Show reply preview
  showReplyPreview();
  
  // Focus input
  document.getElementById('messageInput').focus();
}

function editMessage(messageId) {
  console.log('Editing message:', messageId);
  
  // Find the message element
  const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
  if (!messageEl) return;
  
  const messageTextEl = messageEl.querySelector('.message-text');
  const currentText = messageTextEl.textContent;
  
  // Set editing state
  editingMessage = messageId;
  messageEl.classList.add('message-editing');
  
  // Create edit form
  const editForm = document.createElement('div');
  editForm.className = 'message-edit-form';
  editForm.innerHTML = `
    <textarea class="message-edit-input" placeholder="Edit message...">${currentText}</textarea>
    <div class="message-edit-actions">
      <button class="message-edit-btn message-edit-save" data-action="save-edit" data-message-id="${messageId}">Save</button>
      <button class="message-edit-btn message-edit-cancel" data-action="cancel-edit" data-message-id="${messageId}">Cancel</button>
    </div>
  `;
  
  // Hide original text and show edit form
  messageTextEl.style.display = 'none';
  messageTextEl.parentNode.appendChild(editForm);
  
  // Focus and select text
  const textarea = editForm.querySelector('.message-edit-input');
  textarea.focus();
  textarea.select();
  
  // Add event listeners for edit form buttons
  editForm.addEventListener('click', function(e) {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;
    
    e.preventDefault();
    e.stopPropagation();
    
    const action = btn.dataset.action;
    const msgId = btn.dataset.messageId;
    
    if (action === 'save-edit') {
      saveMessageEdit(msgId);
    } else if (action === 'cancel-edit') {
      cancelMessageEdit(msgId);
    }
  });
}

function saveMessageEdit(messageId) {
  const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
  const editForm = messageEl.querySelector('.message-edit-form');
  const newText = editForm.querySelector('.message-edit-input').value.trim();
  
  if (!newText) {
    alert('Message cannot be empty');
    return;
  }
  
  // Send edit request
  fetch('/messages/api/edit', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      messageId: messageId,
      newText: newText,
      channelId: currentChannel
    })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      // Update message display
      const messageTextEl = messageEl.querySelector('.message-text');
      messageTextEl.innerHTML = formatMessage(newText);
      messageTextEl.classList.add('message-edited');
      
      // Clean up edit form
      cancelMessageEdit(messageId);
    } else {
      alert('Failed to edit message: ' + (data.error || 'Unknown error'));
    }
  })
  .catch(err => {
    console.error('Error editing message:', err);
    alert('Failed to edit message');
  });
}

function cancelMessageEdit(messageId) {
  const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
  const editForm = messageEl.querySelector('.message-edit-form');
  const messageTextEl = messageEl.querySelector('.message-text');
  
  // Remove edit form and show original text
  if (editForm) editForm.remove();
  messageTextEl.style.display = 'block';
  messageEl.classList.remove('message-editing');
  
  editingMessage = null;
}

function deleteMessage(messageId) {
  if (!confirm('Are you sure you want to delete this message?')) {
    return;
  }
  
  console.log('Deleting message:', messageId);
  
  fetch('/messages/api/delete', {
    method: 'DELETE',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      messageId: messageId,
      channelId: currentChannel
    })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      // Mark message as deleted
      const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
      if (messageEl) {
        messageEl.classList.add('message-deleted');
        const messageTextEl = messageEl.querySelector('.message-text');
        messageTextEl.textContent = 'This message was deleted';
        
        // Remove message actions
        const actionsEl = messageEl.querySelector('.message-actions');
        if (actionsEl) actionsEl.remove();
      }
    } else {
      alert('Failed to delete message: ' + (data.error || 'Unknown error'));
    }
  })
  .catch(err => {
    console.error('Error deleting message:', err);
    alert('Failed to delete message');
  });
}

function showMessageOptions(messageId) {
  console.log('Showing options for message:', messageId);
  // Implementation for message context menu
  const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
  if (!messageEl) return;
  
  // Simple implementation - could be enhanced with a proper context menu
  const isOwnMessage = messageEl.classList.contains('own-message');
  
  let options = ['Copy Message', 'Report Message'];
  if (isOwnMessage) {
    options.unshift('Delete Message');
  }
  
  const choice = prompt('Message Options:\n' + options.map((opt, i) => `${i + 1}. ${opt}`).join('\n') + '\n\nEnter option number:');
  
  if (choice) {
    const optionIndex = parseInt(choice) - 1;
    const selectedOption = options[optionIndex];
    
    switch (selectedOption) {
      case 'Delete Message':
        deleteMessage(messageId);
        break;
      case 'Copy Message':
        const messageText = messageEl.querySelector('.message-text').textContent;
        navigator.clipboard.writeText(messageText);
        break;
      case 'Report Message':
        alert('Message reported to administrators');
        break;
    }
  }
}

function showReplyPreview() {
