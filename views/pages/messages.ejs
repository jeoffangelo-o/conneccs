function openInNewTab() {
  if (currentDocumentUrl) {
    window.open(currentDocumentUrl, '_blank');
  }
}

function closeDocumentPreview() {
  document.getElementById('documentPreviewModal').style.display = 'none';
  document.getElementById('documentPreviewFrame').src = '';
  document.getElementById('documentPreviewFrame').style.display = 'none';
  document.getElementById('documentLoadingIndicator').style.display = 'block';
}

function downloadDocument() {
  if (currentDocumentUrl) {
    const link = document.createElement('a');
    link.href = currentDocumentUrl;
    link.download = '';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }
}

// Close modals when clicking outside
window.onclick = function(event) {
  const imageModal = document.getElementById('imagePreviewModal');
  const documentModal = document.getElementById('documentPreviewModal');
  const driveModal = document.getElementById('driveModal');
  
  if (event.target === imageModal) {
    closeImagePreview();
  } else if (event.target === documentModal) {
    closeDocumentPreview();
  } else if (event.target === driveModal) {
    closeGoogleDrive();
  }
};
// Auto-load messages on page load
(function() {
  // Load theme
  const savedTheme = localStorage.getItem('theme') || 'dark';
  document.documentElement.setAttribute('data-theme', savedTheme);
  
  // Auto-load messages on page load
  console.log('Messages page loaded. Loading messages...');
  loadMessages();
  
  // Set up input handlers
  const messageInput = document.getElementById('messageInput');
  const chatInputWrapper = document.querySelector('.chat-input-wrapper');
  
  if (messageInput && chatInputWrapper) {
    messageInput.addEventListener('input', function() {
      // Show/hide send button based on content
      if (this.value.trim() || attachedFiles.length > 0) {
        chatInputWrapper.classList.add('has-content');
      } else {
        chatInputWrapper.classList.remove('has-content');
      }
      
      // Auto-resize textarea
      this.style.height = 'auto';
      this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });
    
    // Handle Enter key
    messageInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        document.getElementById('messageForm').dispatchEvent(new Event('submit'));
      }
    });
  }
  
  // Set up event delegation for message action buttons
  const chatMessages = document.getElementById('chatMessages');
  if (chatMessages) {
    chatMessages.addEventListener('click', function(e) {
      const actionBtn = e.target.closest('.message-action-btn');
      if (!actionBtn) return;
      
      e.preventDefault();
      e.stopPropagation();
      
      const action = actionBtn.dataset.action;
      const messageId = actionBtn.dataset.messageId;
      const emoji = actionBtn.dataset.emoji;
      
      console.log('Message action clicked:', action, messageId);
      
      switch (action) {
        case 'reaction':
          if (emoji) {
            addReaction(messageId, emoji);
          }
          break;
        case 'reply':
          replyToMessage(messageId);
          break;
        case 'edit':
          editMessage(messageId);
          break;
        case 'delete':
          deleteMessage(messageId);
          break;
        case 'more':
          showMessageOptions(messageId);
          break;
        default:
          console.warn('Unknown message action:', action);
      }
    });
  }
})();
</script>

