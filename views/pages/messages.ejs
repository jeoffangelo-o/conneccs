    messageEl.querySelector('.message-content').appendChild(reactionsEl);
  }
  
  reactionsEl.innerHTML = reactions.map(reaction => `
    <div class="message-reaction ${reaction.users.includes(currentUser.id) ? 'reacted' : ''}" 
         data-action="toggle-reaction" data-message-id="${messageId}" data-emoji="${reaction.emoji}">
