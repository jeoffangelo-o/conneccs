// Document preview functions
function openDocumentPreview(documentUrl, documentName, documentType) {
  currentDocumentUrl = documentUrl;
  document.getElementById('documentPreviewTitle').textContent = documentName;
  
  const iframe = document.getElementById('documentPreviewFrame');
  
  if (documentType === 'application/pdf') {
    // For PDFs, use the browser's built-in PDF viewer
    iframe.src = documentUrl;
  } else if (documentType && (documentType.includes('document') || documentType.includes('word') || documentType.includes('sheet') || documentType.includes('presentation'))) {
    // For Office documents, try multiple preview methods
    tryDocumentPreview(iframe, documentUrl, documentName, documentType);
  } else {
    // Fallback for other document types
    iframe.src = documentUrl;
  }
  
  document.getElementById('documentPreviewModal').style.display = 'flex';
}

// Document preview functions
function openDocumentPreview(documentUrl, documentName, documentType) {
  currentDocumentUrl = documentUrl;
  document.getElementById('documentPreviewTitle').textContent = documentName;
  
  // Show loading indicator
  document.getElementById('documentLoadingIndicator').style.display = 'block';
  document.getElementById('documentPreviewFrame').style.display = 'none';
  
  const iframe = document.getElementById('documentPreviewFrame');
  
  if (documentType === 'application/pdf') {
    // For PDFs, use the browser's built-in PDF viewer
    iframe.src = documentUrl;
    setupIframeLoadHandlers(iframe);
  } else if (documentType && (documentType.includes('document') || documentType.includes('word') || documentType.includes('sheet') || documentType.includes('presentation'))) {
    // For Office documents, try multiple preview methods
    tryDocumentPreview(iframe, documentUrl, documentName, documentType);
  } else {
    // Fallback for other document types
    iframe.src = documentUrl;
    setupIframeLoadHandlers(iframe);
  }
  
  document.getElementById('documentPreviewModal').style.display = 'flex';
}

function setupIframeLoadHandlers(iframe) {
  iframe.onload = function() {
    document.getElementById('documentLoadingIndicator').style.display = 'none';
    iframe.style.display = 'block';
  };
  
  // Set a timeout to hide loading indicator even if onload doesn't fire
  setTimeout(() => {
    document.getElementById('documentLoadingIndicator').style.display = 'none';
    iframe.style.display = 'block';
  }, 5000);
}

function tryDocumentPreview(iframe, documentUrl, documentName, documentType) {
  const fullUrl = window.location.origin + documentUrl;
  
  // Try different preview services in order
  const previewMethods = [
    // Method 1: Microsoft Office Online Viewer
    `https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(fullUrl)}`,
    // Method 2: Google Docs Viewer
    `https://docs.google.com/viewer?url=${encodeURIComponent(fullUrl)}&embedded=true`,
    // Method 3: Direct file view
    documentUrl
  ];
  
  let currentMethodIndex = 0;
  
  function tryNextMethod() {
    if (currentMethodIndex >= previewMethods.length) {
      // All methods failed, show error page
      showPreviewError(iframe, documentUrl, documentName);
      return;
    }
    
    const currentUrl = previewMethods[currentMethodIndex];
    console.log(`Trying preview method ${currentMethodIndex + 1}: ${currentUrl}`);
    
    iframe.src = currentUrl;
    
    // Set up timeout for this method
    const timeout = setTimeout(() => {
      console.log(`Method ${currentMethodIndex + 1} timed out, trying next...`);
      currentMethodIndex++;
      tryNextMethod();
    }, 8000); // 8 second timeout per method
    
    iframe.onload = function() {
      clearTimeout(timeout);
      console.log(`Method ${currentMethodIndex + 1} loaded successfully`);
      document.getElementById('documentLoadingIndicator').style.display = 'none';
      iframe.style.display = 'block';
    };
    
    iframe.onerror = function() {
      clearTimeout(timeout);
      console.log(`Method ${currentMethodIndex + 1} failed, trying next...`);
      currentMethodIndex++;
      tryNextMethod();
    };
  }
  
  tryNextMethod();
}

function showPreviewError(iframe, documentUrl, documentName) {
