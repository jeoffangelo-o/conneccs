<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <% const actionLabel = null; const actionHref = ''; %>
  <%- include('../partials/topbar') %>

  <div class="page-body">
    
    <!-- Back Button -->
    <div style="margin-bottom: 20px;">
      <a href="/documents" class="btn btn-secondary btn-sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        Back to Documents
      </a>
    </div>

    <!-- Folder Header -->
    <div class="folder-header-card fade-in">
      <div class="folder-header-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <div class="folder-header-content">
        <h2 class="folder-header-title"><%= folder.name %></h2>
        <p class="folder-header-desc"><%= folder.description %></p>
        <div class="folder-header-meta">
          <span><%- icons.calendar %> Created: <%= folder.createdAt %></span>
          <span><%- icons.user %> By: <%= folder.createdBy %></span>
          <span>
            <% if (isPastDeadline) { %>
              <span class="badge badge-red">Deadline passed</span>
            <% } else if (isApproaching) { %>
              <span class="badge badge-orange"><%= daysUntilDeadline %> days left</span>
            <% } else { %>
              <span class="badge badge-green">Due: <%= folder.deadline %></span>
            <% } %>
          </span>
        </div>
      </div>
      <div class="folder-header-actions">
        <button onclick="openUploadModal()" class="btn btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          Upload File
        </button>
      </div>
    </div>

    <!-- Files List -->
    <div class="panel fade-in delay-1">
      <div class="panel-header">
        <div class="panel-title"><span class="dot"></span> Files (<%= files.length %>)</div>
        <div style="display: flex; gap: 8px;">
          <select class="filter-select" onchange="filterFiles(this.value)">
            <option value="all">All Files</option>
            <option value="submitted">Submitted</option>
            <option value="approved">Approved</option>
          </select>
        </div>
      </div>
      <div class="panel-body" style="padding: 0;">
        <% if (files.length === 0) { %>
          <div class="empty-state">
            <div class="icon"><%- icons.folder %></div>
            <p>No files uploaded yet</p>
          </div>
        <% } else { %>
          <div class="files-list">
            <% files.forEach((file, idx) => { %>
              <div class="file-item fade-in" style="animation-delay:<%= idx * 0.03 %>s" data-status="<%= file.status %>">
                <div class="file-icon">
                  <% if (file.type.includes('pdf')) { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                      <polyline points="14 2 14 8 20 8"/>
                      <line x1="16" y1="13" x2="8" y2="13"/>
                      <line x1="16" y1="17" x2="8" y2="17"/>
                      <polyline points="10 9 9 9 8 9"/>
                    </svg>
                  <% } else if (file.type.includes('sheet') || file.type.includes('excel')) { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                      <polyline points="14 2 14 8 20 8"/>
                      <line x1="8" y1="13" x2="16" y2="17"/>
                      <line x1="8" y1="17" x2="16" y2="13"/>
                    </svg>
                  <% } else { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
                      <polyline points="13 2 13 9 20 9"/>
                    </svg>
                  <% } %>
                </div>
                <div class="file-info">
                  <div class="file-name"><%= file.name %></div>
                  <div class="file-meta">
                    <span><%- icons.user %> <%= file.uploadedBy %></span>
                    <span><%- icons.calendar %> <%= new Date(file.uploadedAt).toLocaleDateString() %></span>
                    <span><%- icons.database %> <%= file.size %></span>
                    <% if (file.metadata.category) { %>
                      <span class="badge badge-gray" style="font-size: 0.65rem;"><%= file.metadata.category %></span>
                    <% } %>
                  </div>
                </div>
                <div class="file-status">
                  <% if (file.status === 'submitted') { %>
                    <span class="badge badge-yellow">Submitted</span>
                  <% } else if (file.status === 'approved') { %>
                    <span class="badge badge-green">Approved</span>
                  <% } else { %>
                    <span class="badge badge-gray">Draft</span>
                  <% } %>
                </div>
                <div class="file-actions">
                  <button class="btn btn-secondary btn-sm" onclick="downloadFile(<%= file.id %>)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                      <polyline points="7 10 12 15 17 10"/>
                      <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                  </button>
                  <button class="btn btn-secondary btn-sm" onclick="viewFileDetails(<%= file.id %>)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="11" cy="11" r="8"/>
                      <path d="m21 21-4.35-4.35"/>
                    </svg>
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</div>

<!-- Upload Modal -->
<div id="uploadModal" class="modal" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Upload File to <%= folder.name %></h3>
      <button onclick="closeUploadModal()" class="modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <form id="uploadForm" enctype="multipart/form-data">
        <div class="form-group">
          <label>File</label>
          <input type="file" name="file" required class="form-input">
        </div>
        <div class="form-group">
          <label>Category</label>
          <select name="category" class="form-select">
            <option value="Accomplishment Report">Accomplishment Report</option>
            <option value="Extension Output">Extension Output</option>
            <option value="Research Paper">Research Paper</option>
            <option value="IPCR">IPCR</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label>Period</label>
          <input type="text" name="period" placeholder="e.g., Q1 2025" class="form-input">
        </div>
        <div class="form-group">
          <label>Notes (Optional)</label>
          <textarea name="notes" class="form-textarea" rows="3" placeholder="Add any additional notes..."></textarea>
        </div>
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
          <button type="button" onclick="closeUploadModal()" class="btn btn-secondary">Cancel</button>
          <button type="submit" class="btn btn-primary">Upload</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openUploadModal() {
  document.getElementById('uploadModal').style.display = 'flex';
}

function closeUploadModal() {
  document.getElementById('uploadModal').style.display = 'none';
}

function filterFiles(status) {
  const items = document.querySelectorAll('.file-item');
  items.forEach(item => {
    if (status === 'all' || item.dataset.status === status) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
}

function downloadFile(fileId) {
  alert('Download file ' + fileId);
}

function viewFileDetails(fileId) {
  alert('View details for file ' + fileId);
}

document.getElementById('uploadForm').addEventListener('submit', function(e) {
  e.preventDefault();
  alert('File upload functionality will be implemented with actual file handling');
  closeUploadModal();
});
</script>

<%- include('../partials/footer') %>
