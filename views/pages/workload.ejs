<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <% const actionLabel = null; const actionHref = ''; %>
  <%- include('../partials/topbar') %>

  <div class="page-body">

    <!-- Summary -->
    <div class="stat-grid fade-in" style="grid-template-columns: repeat(4, 1fr); margin-bottom:24px">
      <% const overloaded = workload.filter(w => w.overloaded && w.status === 'Active') %>
      <% const avgLoad = (workload.filter(w=>w.status==='Active').reduce((s,w) => s + w.totalLoad, 0) / workload.filter(w=>w.status==='Active').length).toFixed(1) %>
      <div class="stat-card blue">
        <div class="stat-icon">👥</div>
        <div class="stat-label">Active Faculty</div>
        <div class="stat-value"><%= workload.filter(w=>w.status==='Active').length %></div>
      </div>
      <div class="stat-card red delay-1">
        <div class="stat-icon">⚡</div>
        <div class="stat-label">Overloaded</div>
        <div class="stat-value"><%= overloaded.length %></div>
        <div class="stat-sub">> 24 units total</div>
      </div>
      <div class="stat-card teal delay-2">
        <div class="stat-icon">⚖️</div>
        <div class="stat-label">Avg. Load</div>
        <div class="stat-value" style="font-size:1.6rem"><%= avgLoad %></div>
        <div class="stat-sub">units per faculty</div>
      </div>
      <div class="stat-card green delay-3">
        <div class="stat-icon">✅</div>
        <div class="stat-label">Balanced</div>
        <div class="stat-value"><%= workload.filter(w=>!w.overloaded && w.status==='Active').length %></div>
      </div>
    </div>

    <!-- Workload Table -->
    <div class="panel fade-in delay-1">
      <div class="panel-header">
        <div class="panel-title"><span class="dot" style="background:var(--teal)"></span> Faculty Workload Distribution</div>
        <div style="display:flex; align-items:center; gap:12px; font-size:0.72rem; color:var(--text3)">
          <span style="display:flex; align-items:center; gap:5px"><span style="width:10px;height:10px;border-radius:2px;background:var(--accent);display:inline-block"></span> Teaching</span>
          <span style="display:flex; align-items:center; gap:5px"><span style="width:10px;height:10px;border-radius:2px;background:var(--teal);display:inline-block"></span> Research</span>
          <span style="display:flex; align-items:center; gap:5px"><span style="width:10px;height:10px;border-radius:2px;background:var(--accent2);display:inline-block"></span> Extension</span>
        </div>
      </div>
      <div class="table-wrap">
        <table style="table-layout: fixed;">
          <thead>
            <tr>
              <th style="width: 200px;">Faculty</th>
              <th style="width: 90px;">Role</th>
              <th style="width: 60px;">Prog</th>
              <th style="width: 60px;">Teach</th>
              <th style="width: 60px;">Res</th>
              <th style="width: 60px;">Ext</th>
              <th style="width: 70px;">Total</th>
              <th style="width: 110px;">Distribution</th>
              <th style="width: 70px;">Status</th>
              <th style="width: 70px;">Flag</th>
            </tr>
          </thead>
          <tbody>
            <% workload.forEach((w, idx) => { %>
            <% const maxLoad = 30; %>
            <tr class="fade-in" style="animation-delay:<%= idx * 0.04 %>s">
              <td>
                <div class="faculty-cell">
                  <div class="avatar avatar-sm" style="<%= w.status === 'On Leave' ? 'opacity:0.4' : '' %>">
                    <%= w.avatar %>
                  </div>
                  <div class="faculty-cell-info">
                    <div class="name" style="font-size: 0.8rem;"><%= w.name %></div>
                    <div class="sub" style="font-size: 0.65rem;"><%= w.email.split('@')[0] %></div>
                  </div>
                </div>
              </td>
              <td><span class="badge badge-gray" style="font-size:0.6rem; padding: 2px 5px;"><%= w.role.split(' ')[0] %></span></td>
              <td style="font-size:0.7rem; color:var(--text3)"><%= w.program %></td>
              <td style="text-align: center;">
                <% if (w.status === 'On Leave') { %>
                  <span style="color:var(--text3)">—</span>
                <% } else { %>
                  <strong style="font-family:var(--font-display); font-size:0.85rem"><%= w.teachingLoad %></strong>
                <% } %>
              </td>
              <td style="text-align: center;">
                <% if (w.status === 'On Leave') { %>
                  <span style="color:var(--text3)">—</span>
                <% } else { %>
                  <strong style="font-family:var(--font-display); font-size:0.85rem"><%= w.researchLoad %></strong>
                <% } %>
              </td>
              <td style="text-align: center;">
                <% if (w.status === 'On Leave') { %>
                  <span style="color:var(--text3)">—</span>
                <% } else { %>
                  <strong style="font-family:var(--font-display); font-size:0.85rem"><%= w.extensionLoad %></strong>
                <% } %>
              </td>
              <td style="text-align: center;">
                <% if (w.status === 'On Leave') { %>
                  <span style="color:var(--text3)">—</span>
                <% } else { %>
                  <div style="font-family:var(--font-display); font-size:0.95rem; font-weight:800; color: <%= w.overloaded ? 'var(--red)' : 'var(--text)' %>">
                    <%= w.totalLoad %>
                  </div>
                <% } %>
              </td>
              <td>
                <% if (w.status !== 'On Leave') { %>
                <div style="display:flex; flex-direction:column; gap:2px;">
                  <div style="display:flex; height:6px; border-radius:99px; overflow:hidden; gap:1px">
                    <div style="width:<%= w.teachingLoad / maxLoad * 100 %>%; background:var(--accent);"></div>
                    <div style="width:<%= w.researchLoad / maxLoad * 100 %>%; background:var(--teal)"></div>
                    <div style="width:<%= w.extensionLoad / maxLoad * 100 %>%; background:var(--accent2);"></div>
                  </div>
                  <div style="font-size:0.58rem; color:var(--text3); white-space: nowrap;">
                    <%= Math.round(w.teachingLoad/maxLoad*100) %>%·<%= Math.round(w.researchLoad/maxLoad*100) %>%·<%= Math.round(w.extensionLoad/maxLoad*100) %>%
                  </div>
                </div>
                <% } else { %>
                  <span style="color:var(--text3); font-size:0.75rem">—</span>
                <% } %>
              </td>
              <td>
                <% if (w.status === 'On Leave') { %>
                  <span class="badge badge-gray" style="font-size:0.6rem;">Leave</span>
                <% } else { %>
                  <span class="badge badge-green" style="font-size:0.6rem;">Active</span>
                <% } %>
              </td>
              <td>
                <% if (w.overloaded && w.status === 'Active') { %>
                  <span class="badge badge-red" style="font-size:0.6rem;" title="Overloaded">⚡</span>
                <% } else if (w.status === 'Active') { %>
                  <span class="badge badge-green" style="font-size:0.6rem;">✓</span>
                <% } else { %>
                  <span style="color:var(--text3)">—</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recommendation -->
    <div class="panel fade-in delay-3">
      <div class="panel-header">
        <div class="panel-title"><span class="dot" style="background:var(--yellow)"></span> System Recommendations</div>
      </div>
      <div class="panel-body">
        <% workload.filter(w => w.overloaded && w.status === 'Active').forEach(w => { %>
        <div style="display:flex; align-items:flex-start; gap:12px; padding:12px; background:rgba(244,63,94,0.06); border:1px solid rgba(244,63,94,0.15); border-radius:var(--radius-sm); margin-bottom:10px">
          <div style="font-size:1.2rem; flex-shrink:0">⚡</div>
          <div>
            <div style="font-size:0.85rem; font-weight:600; color:var(--text)"><%= w.name %> is overloaded (<%= w.totalLoad %> units)</div>
            <div style="font-size:0.78rem; color:var(--text3); margin-top:3px">
              Consider reassigning <%= w.extensionLoad > 4 ? 'extension' : 'research' %> tasks to other available faculty members to bring the total below 24 units.
            </div>
          </div>
        </div>
        <% }) %>
        <% if (workload.filter(w => w.overloaded && w.status === 'Active').length === 0) { %>
        <div style="text-align:center; padding:24px; color:var(--text3); font-size:0.875rem">
          ✅ All active faculty workloads are within recommended limits.
        </div>
        <% } %>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
