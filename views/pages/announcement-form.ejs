<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <% const actionLabel = null; const actionHref = ''; %>
  <%- include('../partials/topbar') %>

  <div class="page-body">
    <div style="max-width: 620px; margin: 0 auto">
      <div style="margin-bottom: 20px">
        <a href="/announcements" class="btn btn-secondary btn-sm">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Back to Announcements
        </a>
      </div>

      <div class="panel fade-in">
        <div class="panel-header">
          <div class="panel-title"><span class="dot" style="background:var(--yellow)"></span> Post Announcement</div>
        </div>
        <div class="panel-body">
          <form action="/announcements/new" method="POST">
            <div class="form-group">
              <label class="form-label">Announcement Title</label>
              <input type="text" name="title" class="form-input" placeholder="Enter announcement title..." required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Target Role</label>
                <select name="targetRole" class="form-select" required>
                  <option value="All">All Roles</option>
                  <option value="Faculty">Faculty</option>
                  <option value="Program Chair">Program Chair</option>
                  <option value="Research Coordinator">Research Coordinator</option>
                  <option value="Dean">Dean</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Priority Level</label>
                <select name="priority" class="form-select" required>
                  <option value="Low">Low</option>
                  <option value="Medium" selected>Medium</option>
                  <option value="High">High</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Message</label>
              <textarea name="message" class="form-textarea" rows="5" placeholder="Write your announcement here..." required></textarea>
            </div>
            <div class="form-group" style="display:flex; align-items:center; gap:8px">
              <input type="checkbox" name="pinned" id="pinned" style="width:16px; height:16px; accent-color:var(--accent)" />
              <label for="pinned" style="font-size:0.83rem; color:var(--text2); cursor:pointer"><%- icons.pin %> Pin this announcement to dashboard</label>
            </div>
            <div style="display:flex; gap:10px; justify-content:flex-end; padding-top:8px; border-top:1px solid var(--border)">
              <a href="/announcements" class="btn btn-secondary">Cancel</a>
              <button type="submit" class="btn btn-primary">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Post Announcement
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
