<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <% const actionLabel = null; const actionHref = ''; %>
  <%- include('../partials/topbar') %>
  <div class="page-body" style="display:flex; align-items:center; justify-content:center; min-height:60vh">
    <div style="text-align:center; max-width:480px">
      <div style="font-size:3rem; margin-bottom:12px; color: var(--red);">
        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block;">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </div>
      <div style="font-family:var(--font-display); font-size:1.5rem; font-weight:800; color:var(--text); margin-bottom:8px">Server Error</div>
      <div style="font-size:0.85rem; color:var(--text3); margin-bottom:24px"><%= error ? error.message : 'An unexpected error occurred.' %></div>
      <a href="/" class="btn btn-primary">← Back to Dashboard</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
