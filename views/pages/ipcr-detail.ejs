<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <% const actionLabel = null; const actionHref = ''; %>
  <%- include('../partials/topbar') %>

  <div class="page-body">
    <div style="max-width: 820px; margin: 0 auto">
      <div style="margin-bottom: 20px">
        <a href="/ipcr" class="btn btn-secondary btn-sm">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Back to IPCR
        </a>
      </div>

      <!-- Profile Header -->
      <div class="profile-card fade-in">
        <div class="avatar avatar-xl" style="background: linear-gradient(135deg, var(--accent2), #3b82f6); border-radius: 14px">
          <%= entry.facultyName.split(' ').map(w => w[0]).slice(0,2).join('') %>
        </div>
        <div style="flex:1">
          <div class="profile-info">
            <div class="profile-name"><%= entry.facultyName %></div>
            <div class="profile-role">IPCR Record · <%= entry.period %></div>
          </div>
          <div class="profile-badges">
            <% if (entry.rating === 'Outstanding') { %>
              <span class="badge badge-green">Outstanding</span>
            <% } else { %>
              <span class="badge badge-blue">Very Satisfactory</span>
            <% } %>
            <% if (entry.status === 'Approved') { %>
              <span class="badge badge-green">Approved</span>
            <% } else if (entry.status === 'For Review') { %>
              <span class="badge badge-yellow">For Review</span>
            <% } else { %>
              <span class="badge badge-gray">Pending Entry</span>
            <% } %>
          </div>
        </div>
        <div style="text-align:right">
          <div style="font-size:0.72rem; color:var(--text3); margin-bottom:4px">Final Score</div>
          <div style="font-family:var(--font-display); font-size:3rem; font-weight:800; letter-spacing:-0.05em; color:var(--text); line-height:1">
            <%= entry.finalScore.toFixed(2) %>
          </div>
          <div style="font-size:0.72rem; color:var(--text3)">out of 5.00</div>
        </div>
      </div>

      <!-- Score Breakdown -->
      <div class="panel fade-in delay-1">
        <div class="panel-header">
          <div class="panel-title"><span class="dot"></span> Score Breakdown</div>
        </div>
        <div class="panel-body">
          <div class="ipcr-score-grid">
            <div class="ipcr-score-item">
              <div class="score" style="color:var(--accent)"><%= entry.teachingScore %></div>
              <div class="label">Teaching</div>
              <div class="progress-bar" style="margin-top:8px"><div class="progress-fill progress-blue" style="width:<%= entry.teachingScore / 5 * 100 %>%"></div></div>
            </div>
            <div class="ipcr-score-item">
              <div class="score" style="color:var(--teal)"><%= entry.researchScore %></div>
              <div class="label">Research</div>
              <div class="progress-bar" style="margin-top:8px"><div class="progress-fill" style="width:<%= entry.researchScore / 5 * 100 %>%; background:var(--teal)"></div></div>
            </div>
            <div class="ipcr-score-item">
              <div class="score" style="color:var(--accent2)"><%= entry.extensionScore %></div>
              <div class="label">Extension</div>
              <div class="progress-bar" style="margin-top:8px"><div class="progress-fill" style="width:<%= entry.extensionScore / 5 * 100 %>%; background:var(--accent2)"></div></div>
            </div>
            <div class="ipcr-score-item">
              <div class="score" style="color:var(--orange)"><%= entry.adminScore %></div>
              <div class="label">Admin</div>
              <div class="progress-bar" style="margin-top:8px"><div class="progress-fill" style="width:<%= entry.adminScore / 5 * 100 %>%; background:var(--orange)"></div></div>
            </div>
          </div>

          <!-- Weighted Score Explanation -->
          <div style="background:var(--bg3); border:1px solid var(--border); border-radius:var(--radius-sm); padding:14px; margin-top:4px">
            <div style="font-size:0.78rem; font-weight:600; color:var(--text2); margin-bottom:8px">Score Formula</div>
            <div style="font-size:0.8rem; color:var(--text3); line-height:1.8">
              Final Score = (Teaching × 0.40) + (Research × 0.25) + (Extension × 0.20) + (Admin × 0.15)<br>
              = (<%= entry.teachingScore %> × 0.40) + (<%= entry.researchScore %> × 0.25) + (<%= entry.extensionScore %> × 0.20) + (<%= entry.adminScore %> × 0.15)<br>
              = <strong style="color:var(--text)"><%= entry.finalScore.toFixed(4) %></strong>
            </div>
          </div>
        </div>
      </div>

      <!-- Review Info -->
      <div class="panel fade-in delay-2">
        <div class="panel-header">
          <div class="panel-title"><span class="dot" style="background:var(--green)"></span> Review Information</div>
          <% if (entry.status === 'For Review') { %>
          <button class="btn btn-primary btn-sm">Approve IPCR</button>
          <% } %>
        </div>
        <div class="panel-body">
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px">
            <div>
              <div style="font-size:0.72rem; color:var(--text3); margin-bottom:4px; text-transform:uppercase; letter-spacing:0.07em">Reviewed By</div>
              <div style="font-size:0.9rem; color:var(--text)"><%= entry.reviewedBy || '— Not yet reviewed —' %></div>
            </div>
            <div>
              <div style="font-size:0.72rem; color:var(--text3); margin-bottom:4px; text-transform:uppercase; letter-spacing:0.07em">Review Date</div>
              <div style="font-size:0.9rem; color:var(--text)"><%= entry.reviewDate || '—' %></div>
            </div>
            <div>
              <div style="font-size:0.72rem; color:var(--text3); margin-bottom:4px; text-transform:uppercase; letter-spacing:0.07em">Period</div>
              <div style="font-size:0.9rem; color:var(--text)"><%= entry.period %></div>
            </div>
            <div>
              <div style="font-size:0.72rem; color:var(--text3); margin-bottom:4px; text-transform:uppercase; letter-spacing:0.07em">Current Status</div>
              <div><%= entry.status === 'Approved' ? '<span class="badge badge-green">Approved</span>' : entry.status === 'For Review' ? '<span class="badge badge-yellow">For Review</span>' : '<span class="badge badge-gray">Pending Entry</span>' %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
