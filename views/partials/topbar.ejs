<div class="topbar">
  <div class="topbar-left">
    <span class="topbar-title"><%= title.split('–')[0].trim() %></span>
    <span class="topbar-breadcrumb">CCS Faculty Portal › <%= title.split('–')[0].trim() %></span>
  </div>
  <div class="topbar-right">
    <% if (typeof actionLabel !== 'undefined' && actionLabel) { %>
      <a href="<%= actionHref %>" class="topbar-btn primary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <%= actionLabel %>
      </a>
    <% } %>
    <a href="/messages" class="notif-btn" title="Messages">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <% const unreadCount = 3; %>
      <% if (unreadCount > 0) { %>
        <span class="notif-badge"><%= unreadCount %></span>
      <% } %>
    </a>
    <a href="/settings" class="notif-btn" title="Settings">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="3"/>
        <path d="M12 1v6m0 6v6m11-7h-6m-6 0H1m11-7a4 4 0 0 1 0 8 4 4 0 0 1 0-8z"/>
      </svg>
    </a>
  </div>
</div>
